modules = ["nodejs-20", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Avatar Cleanup Cron"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pkill -f '/node_modules/.bin/next dev -p 5000 -H 0.0.0.0' || true; npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Avatar Cleanup Cron"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/run-avatar-cleanup-cron.sh"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5000
externalPort = 5000

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000

[deployment]
run = ["sh", "-c", "npx next start -p 3000 -H 0.0.0.0"]
deploymentTarget = "cloudrun"
build = ["sh", "-c", "npm install && npm run build"]
